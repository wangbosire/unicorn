# 静态网关：后台 Admin + 小程序 H5；/api 反代到 api 服务。
FROM node:22-bookworm AS builder
RUN corepack enable && corepack prepare pnpm@10.10.0 --activate
WORKDIR /repo
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY packages ./packages
COPY apps ./apps
RUN pnpm install --frozen-lockfile
ENV VITE_API_BASE_URL=/api
RUN pnpm --filter @unicorn/admin run build
RUN pnpm --filter @unicorn/miniapp run build:h5

FROM nginx:1.27-alpine
RUN rm /etc/nginx/conf.d/default.conf
COPY docker/nginx/default.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /repo/apps/admin/dist /usr/share/nginx/html
COPY --from=builder /repo/apps/miniapp/dist /usr/share/nginx/html/h5
EXPOSE 80
