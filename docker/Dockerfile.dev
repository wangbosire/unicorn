# 本地热更新：安装 monorepo 依赖 + Prisma Client；运行时挂载源码后由 compose 启动 watch。
# 与生产镜像分离，避免把 watch 依赖打进线上构建。
FROM node:22-bookworm
RUN apt-get update \
  && apt-get install -y --no-install-recommends openssl ca-certificates \
  && rm -rf /var/lib/apt/lists/*
RUN corepack enable && corepack prepare pnpm@10.10.0 --activate
WORKDIR /repo
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY packages ./packages
COPY apps ./apps
COPY docker ./docker
RUN chmod +x docker/api-dev-entrypoint.sh
RUN pnpm install --frozen-lockfile
ENV DATABASE_URL="mysql://root:placeholder@127.0.0.1:3306/placeholder"
RUN pnpm --filter @unicorn/api exec prisma generate
