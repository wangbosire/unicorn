generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// 后台用户状态。
enum AdminUserStatus {
  /// 可正常登录并参与后台操作。
  ACTIVE
  /// 已停用，不允许继续登录。
  DISABLED
}

/// 角色状态。
enum RoleStatus {
  /// 角色可正常分配与生效。
  ENABLED
  /// 角色已停用，不再参与权限计算。
  DISABLED
}

/// 权限类型。
enum PermissionType {
  /// 页面访问类权限。
  PAGE
  /// 页面内动作类权限。
  ACTION
}

/// 会员状态。
enum MemberStatus {
  /// 会员可正常登录和领取藏品。
  ACTIVE
  /// 会员被冻结，不允许继续执行关键操作。
  FROZEN
}

/// 微信渠道类型。
enum WechatChannelType {
  /// 微信小程序。
  MINIAPP
  /// 微信公众号。
  MP
}

/// 系列状态。
enum SeriesStatus {
  /// 系列可正常用于发行批次和后台展示。
  ENABLED
  /// 系列已停用，不允许继续新增有效发行动作。
  DISABLED
}

/// 发行批次状态。
enum IssuanceBatchStatus {
  /// 批次可正常生成和发放激活码。
  ENABLED
  /// 批次已停用，不允许继续生成激活码。
  DISABLED
}

/// 激活码状态。
enum ActivationCodeStatus {
  /// 已创建但尚未正式发放。
  UNISSUED
  /// 已发放给渠道或用户，但尚未使用。
  ISSUED
  /// 已被会员成功使用。
  USED
  /// 已被人工或系统作废。
  VOIDED
  /// 已超过有效期失效。
  EXPIRED
}

/// 藏品资产状态。
enum CollectionStatus {
  /// 已生成但尚未被会员领取。
  PENDING_CLAIM
  /// 已被会员领取并归属到当前持有人。
  OWNED
  /// 资产被冻结，不允许继续流转或编辑。
  FROZEN
}

/// 藏品内容编辑状态。
enum CollectionContentEditStatus {
  /// 草稿态，可继续编辑。
  DRAFT
  /// 已提交审核，暂不可编辑。
  UNDER_REVIEW
  /// 审核拒绝，允许继续修改后重提。
  REJECTED
  /// 审核通过，内容可作为已确认版本使用。
  APPROVED
}

/// 藏品内容公开状态。
enum CollectionContentPublishStatus {
  /// 尚未对外公开展示。
  UNPUBLISHED
  /// 已公开展示。
  PUBLISHED
  /// 已下架，不再对外展示。
  TAKEDOWN
}

/// 藏品内容审核阶段。
enum CollectionContentReviewStage {
  /// 机器审核阶段。
  MACHINE
  /// 人工审核阶段。
  MANUAL
}

/// 藏品内容审核状态。
enum CollectionContentReviewStatus {
  /// 待机器审核。
  PENDING_MACHINE
  /// 机器审核通过。
  MACHINE_APPROVED
  /// 机器审核拒绝。
  MACHINE_REJECTED
  /// 待人工审核。
  PENDING_MANUAL
  /// 人工审核通过。
  MANUAL_APPROVED
  /// 人工审核拒绝。
  MANUAL_REJECTED
}

/// 藏品内容审核来源。
enum CollectionContentReviewSource {
  /// 由系统自动执行审核。
  SYSTEM
  /// 由后台管理员执行审核。
  ADMIN
}

/// 评论审核状态。
enum CollectionCommentStatus {
  /// 待机器审核。
  PENDING_MACHINE
  /// 机器审核通过。
  MACHINE_APPROVED
  /// 机器审核拒绝。
  MACHINE_REJECTED
  /// 待人工审核。
  PENDING_MANUAL
  /// 人工审核通过。
  MANUAL_APPROVED
  /// 人工审核拒绝。
  MANUAL_REJECTED
  /// 已公开评论被后台屏蔽。
  BLOCKED
}

/// 评论审核来源。
enum CollectionCommentReviewSource {
  /// 由系统自动执行审核。
  SYSTEM
  /// 由后台管理员执行审核。
  ADMIN
}

/// 通知消息类型。
enum NotificationMessageType {
  /// 激活成功通知。
  ACTIVATE_SUCCESS
  /// 内容审核通过通知。
  CONTENT_APPROVED
  /// 内容审核驳回通知。
  CONTENT_REJECTED
  /// 内容被人工下架通知。
  CONTENT_TAKEDOWN
  /// 评论审核结果通知。
  COMMENT_REVIEW_RESULT
  /// 转让待接收通知。
  TRANSFER_PENDING_ACCEPT
  /// 转让完成通知。
  TRANSFER_COMPLETED
  /// 转让被发起方撤销通知。
  TRANSFER_CANCELLED
  /// 转让超时未确认而过期通知。
  TRANSFER_EXPIRED
  /// 已完成转让被后台人工回滚通知。
  TRANSFER_ROLLED_BACK
}

/// 通知触达渠道。
enum NotificationChannel {
  /// 站内信。
  IN_APP
  /// 小程序订阅消息。
  MINIAPP_SUBSCRIPTION
  /// 公众号通知。
  WECHAT_MP
}

/// 通知发送状态。
enum NotificationDispatchStatus {
  /// 待发送。
  PENDING
  /// 已发送成功。
  SENT
  /// 发送失败。
  FAILED
}

/// 通知模板状态。
enum NotificationTemplateStatus {
  /// 模板可用于派发渲染。
  ACTIVE
  /// 模板已停用，不允许继续作为生效模板。
  DISABLED
}

/// 转让方式。
enum CollectionTransferMode {
  /// 指定会员转让。
  DIRECT_MEMBER
  /// 转让码转让。
  TRANSFER_CODE
}

/// 转让单状态。
enum CollectionTransferStatus {
  /// 已创建，等待目标会员接收。
  PENDING_ACCEPT
  /// 转让已完成。
  COMPLETED
  /// 转让已取消。
  CANCELLED
  /// 转让已过期。
  EXPIRED
  /// 已完成转让被后台人工回滚。
  ROLLED_BACK
}

/// 转让运营处置动作类型。
enum CollectionTransferOperationType {
  /// 后台手动将超时待接收转让释放为已过期。
  ADMIN_EXPIRE
  /// 后台将已完成转让的藏品归属回写为接收方。
  ADMIN_SYNC_OWNER
  /// 后台将已实质到账但仍停留待接收的转让补记为已完成。
  ADMIN_FORCE_COMPLETE
  /// 后台将一条已完成转让回滚为发起方持有。
  ADMIN_FORCE_ROLLBACK
}

/// 健康检查种子表。
model HealthcheckSeed {
  /// 自增主键。
  id        Int      @id @default(autoincrement())
  /// 健康检查作用域标识。
  scope     String
  /// 创建时间。
  createdAt DateTime @default(now()) @map("created_at")

  @@map("healthcheck_seeds")
}

/// 后台用户。
model AdminUser {
  /// 后台用户主键。
  id               String                          @id @default(cuid())
  /// 对外展示和审计使用的后台账号编号。
  accountNo        String                          @unique @map("account_no")
  /// 登录用户名。
  username         String                          @unique
  /// 展示名称。
  displayName      String                          @map("display_name")
  /// 密码哈希值。
  passwordHash     String                          @map("password_hash")
  /// 用户状态。
  status           AdminUserStatus                 @default(ACTIVE)
  /// 最近一次登录时间。
  lastLoginAt      DateTime?                       @map("last_login_at")
  /// 创建时间。
  createdAt        DateTime                        @default(now()) @map("created_at")
  /// 更新时间。
  updatedAt        DateTime                        @updatedAt @map("updated_at")
  /// 后台用户拥有的角色关系。
  roles            AdminUserRole[]
  /// 该管理员审核过的内容记录。
  reviewedItems    CollectionContentReviewRecord[]
  /// 该管理员审核过的评论记录。
  reviewedComments CollectionCommentReviewRecord[]
  /// 该管理员执行过的转让运营处置记录。
  transferOperationRecords CollectionTransferOperationRecord[]

  @@map("admin_users")
}

/// 角色定义。
model Role {
  /// 角色主键。
  id          String           @id @default(cuid())
  /// 角色唯一标识。
  roleKey     String           @unique @map("role_key")
  /// 角色名称。
  roleName    String           @map("role_name")
  /// 角色状态。
  status      RoleStatus       @default(ENABLED)
  /// 创建时间。
  createdAt   DateTime         @default(now()) @map("created_at")
  /// 更新时间。
  updatedAt   DateTime         @updatedAt @map("updated_at")
  /// 被分配该角色的后台用户关系。
  users       AdminUserRole[]
  /// 该角色拥有的权限关系。
  permissions RolePermission[]

  @@map("roles")
}

/// 权限定义。
model Permission {
  /// 权限主键。
  id             String           @id @default(cuid())
  /// 权限唯一标识。
  permissionKey  String           @unique @map("permission_key")
  /// 权限显示名称。
  permissionName String           @map("permission_name")
  /// 权限类别。
  permissionType PermissionType   @map("permission_type")
  /// 创建时间。
  createdAt      DateTime         @default(now()) @map("created_at")
  /// 更新时间。
  updatedAt      DateTime         @updatedAt @map("updated_at")
  /// 拥有该权限的角色关系。
  roles          RolePermission[]

  @@map("permissions")
}

/// 后台用户与角色关系表。
model AdminUserRole {
  /// 关系主键。
  id          String    @id @default(cuid())
  /// 后台用户外键。
  adminUserId String    @map("admin_user_id")
  /// 角色外键。
  roleId      String    @map("role_id")
  /// 建立关联的时间。
  createdAt   DateTime  @default(now()) @map("created_at")
  /// 后台用户实体。
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id])
  /// 角色实体。
  role        Role      @relation(fields: [roleId], references: [id])

  /// 同一后台用户与同一角色只允许建立一条关系。
  @@unique([adminUserId, roleId])
  @@map("admin_user_roles")
}

/// 角色与权限关系表。
model RolePermission {
  /// 关系主键。
  id           String     @id @default(cuid())
  /// 角色外键。
  roleId       String     @map("role_id")
  /// 权限外键。
  permissionId String     @map("permission_id")
  /// 建立关联的时间。
  createdAt    DateTime   @default(now()) @map("created_at")
  /// 角色实体。
  role         Role       @relation(fields: [roleId], references: [id])
  /// 权限实体。
  permission   Permission @relation(fields: [permissionId], references: [id])

  /// 同一角色与同一权限只允许建立一条关系。
  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

/// 会员主账户。
model Member {
  /// 会员主键。
  id                    String                     @id @default(cuid())
  /// 对外展示和跨系统追踪使用的会员编号。
  memberNo              String                     @unique @map("member_no")
  /// 会员昵称。
  nickname              String
  /// 会员头像地址。
  avatarUrl             String?                    @map("avatar_url")
  /// 会员手机号，可能为空。
  mobile                String?
  /// 会员状态。
  status                MemberStatus               @default(ACTIVE)
  /// 注册时间。
  registeredAt          DateTime                   @default(now()) @map("registered_at")
  /// 创建时间。
  createdAt             DateTime                   @default(now()) @map("created_at")
  /// 更新时间。
  updatedAt             DateTime                   @updatedAt @map("updated_at")
  /// 微信渠道绑定关系。
  wechatBindings        MemberWechatBinding[]
  /// 当前名下持有的藏品。
  ownedCollections      Collection[]               @relation("CollectionCurrentOwner")
  /// 该会员已使用过的激活码。
  usedActivationCodes   ActivationCode[]           @relation("ActivationCodeUsedByMember")
  /// 由该会员创建的内容版本。
  createdContentVersion CollectionContentVersion[]
  /// 由该会员发布的评论。
  comments              CollectionComment[]
  /// 面向该会员的通知消息。
  notifications         NotificationMessage[]
  /// 该会员发起的转让单。
  outgoingTransfers     CollectionTransferOrder[]    @relation("CollectionTransferFromMember")
  /// 该会员接收的转让单。
  incomingTransfers     CollectionTransferOrder[]    @relation("CollectionTransferToMember")

  /// 支撑按手机号检索会员的后台查询场景。
  @@index([mobile])
  @@map("members")
}

/// 会员微信绑定关系。
model MemberWechatBinding {
  /// 绑定关系主键。
  id          String            @id @default(cuid())
  /// 会员外键。
  memberId    String            @map("member_id")
  /// 渠道类型，小程序或公众号。
  channelType WechatChannelType @map("channel_type")
  /// 渠道内唯一 openid。
  openid      String
  /// 可用于账号归并的 unionid。
  unionid     String?
  /// 绑定时间。
  boundAt     DateTime          @default(now()) @map("bound_at")
  /// 创建时间。
  createdAt   DateTime          @default(now()) @map("created_at")
  /// 更新时间。
  updatedAt   DateTime          @updatedAt @map("updated_at")
  /// 关联会员实体。
  member      Member            @relation(fields: [memberId], references: [id])

  /// 保证同一渠道下的 openid 只能绑定到一个会员。
  @@unique([channelType, openid])
  /// 支撑通过 unionid 做账号归并或补绑查询。
  @@index([unionid])
  /// 支撑按会员查询其全部微信绑定关系。
  @@index([memberId])
  @@map("member_wechat_bindings")
}

/// 藏品系列定义。
model Series {
  /// 系列主键。
  id          String          @id @default(cuid())
  /// 对外展示的系列编号。
  seriesNo    String          @unique @map("series_no")
  /// 系列名称。
  name        String
  /// 系列描述。
  description String
  /// 系列状态。
  status      SeriesStatus    @default(ENABLED)
  /// 创建人标识，当前阶段先使用字符串存储。
  createdBy   String?         @map("created_by")
  /// 更新人标识，当前阶段先使用字符串存储。
  updatedBy   String?         @map("updated_by")
  /// 创建时间。
  createdAt   DateTime        @default(now()) @map("created_at")
  /// 更新时间。
  updatedAt   DateTime        @updatedAt @map("updated_at")
  /// 该系列下的发行批次。
  batches     IssuanceBatch[]
  /// 该系列下已生成的藏品资产。
  collections Collection[]

  /// 支撑后台按状态筛选系列列表。
  @@index([status])
  @@map("series")
}

/// 发行批次定义。
model IssuanceBatch {
  /// 批次主键。
  id                String              @id @default(cuid())
  /// 对外展示的批次编号。
  batchNo           String              @unique @map("batch_no")
  /// 所属系列外键。
  seriesId          String              @map("series_id")
  /// 批次名称。
  name              String
  /// 计划发行数量。
  quantity          Int
  /// 激活有效开始时间。
  activateValidFrom DateTime            @map("activate_valid_from")
  /// 激活有效结束时间。
  activateValidTo   DateTime            @map("activate_valid_to")
  /// 批次状态。
  status            IssuanceBatchStatus @default(ENABLED)
  /// 运营备注。
  remark            String?
  /// 创建人标识，当前阶段先使用字符串存储。
  createdBy         String?             @map("created_by")
  /// 更新人标识，当前阶段先使用字符串存储。
  updatedBy         String?             @map("updated_by")
  /// 创建时间。
  createdAt         DateTime            @default(now()) @map("created_at")
  /// 更新时间。
  updatedAt         DateTime            @updatedAt @map("updated_at")
  /// 所属系列实体。
  series            Series              @relation(fields: [seriesId], references: [id])
  /// 该批次下生成的藏品资产。
  collections       Collection[]
  /// 该批次下生成的激活码。
  activationCodes   ActivationCode[]

  /// 支撑按所属系列查询批次列表。
  @@index([seriesId])
  /// 支撑后台按状态筛选批次列表。
  @@index([status])
  @@map("issuance_batches")
}

/// 藏品主实体。
/// 表示数字资产本体，不等同于可公开展示的内容版本。
model Collection {
  /// 藏品主键。
  id                   String                          @id @default(cuid())
  /// 对外展示的藏品编号。
  collectionNo         String                          @unique @map("collection_no")
  /// 所属系列外键。
  seriesId             String                          @map("series_id")
  /// 所属批次外键。
  batchId              String                          @map("batch_id")
  /// 当前藏品资产状态。
  status               CollectionStatus                @default(PENDING_CLAIM)
  /// 当前拥有者会员外键，未领取时为空。
  currentOwnerMemberId String?                         @map("current_owner_member_id")
  /// 实际领取时间。
  claimedAt            DateTime?                       @map("claimed_at")
  /// 创建时间。
  createdAt            DateTime                        @default(now()) @map("created_at")
  /// 更新时间。
  updatedAt            DateTime                        @updatedAt @map("updated_at")
  /// 所属系列实体。
  series               Series                          @relation(fields: [seriesId], references: [id])
  /// 所属发行批次实体。
  batch                IssuanceBatch                   @relation(fields: [batchId], references: [id])
  /// 当前持有人会员实体。
  currentOwnerMember   Member?                         @relation("CollectionCurrentOwner", fields: [currentOwnerMemberId], references: [id])
  /// 与该藏品一一对应的激活码。
  activationCode       ActivationCode?
  /// 藏品下的内容版本列表。
  contentVersions      CollectionContentVersion[]
  /// 藏品下的审核记录列表。
  reviewRecords        CollectionContentReviewRecord[]
  /// 藏品下的公开评论。
  comments             CollectionComment[]
  /// 藏品关联的转让单列表。
  transferOrders       CollectionTransferOrder[]

  /// 支撑按所属系列聚合或筛选藏品。
  @@index([seriesId])
  /// 支撑按发行批次查询生成结果与审核范围。
  @@index([batchId])
  /// 支撑按当前持有人查询我的藏品列表。
  @@index([currentOwnerMemberId])
  /// 支撑按藏品资产状态筛选。
  @@index([status])
  @@map("collections")
}

/// 激活码实体。
/// 每个激活码和藏品一一对应。
model ActivationCode {
  /// 激活码主键。
  id             String               @id @default(cuid())
  /// 会员输入的唯一激活码。
  code           String               @unique
  /// 所属批次外键。
  batchId        String               @map("batch_id")
  /// 对应藏品外键，一码一藏品。
  /// 字段级唯一约束保证一个藏品只能对应一个激活码。
  collectionId   String               @unique @map("collection_id")
  /// 激活码状态。
  status         ActivationCodeStatus @default(UNISSUED)
  /// 发放渠道标识。
  issuedChannel  String?              @map("issued_channel")
  /// 发放时间。
  issuedAt       DateTime?            @map("issued_at")
  /// 使用该激活码的会员外键。
  usedByMemberId String?              @map("used_by_member_id")
  /// 实际使用时间。
  usedAt         DateTime?            @map("used_at")
  /// 失效时间。
  expiredAt      DateTime?            @map("expired_at")
  /// 作废时间。
  voidedAt       DateTime?            @map("voided_at")
  /// 创建时间。
  createdAt      DateTime             @default(now()) @map("created_at")
  /// 更新时间。
  updatedAt      DateTime             @updatedAt @map("updated_at")
  /// 所属发行批次实体。
  batch          IssuanceBatch        @relation(fields: [batchId], references: [id])
  /// 一一对应的藏品实体。
  collection     Collection           @relation(fields: [collectionId], references: [id])
  /// 实际使用该激活码的会员实体。
  usedByMember   Member?              @relation("ActivationCodeUsedByMember", fields: [usedByMemberId], references: [id])

  /// 支撑按批次查询激活码列表与生成统计。
  @@index([batchId])
  /// 支撑按激活码状态筛选后台列表。
  @@index([status])
  /// 支撑按使用会员追踪激活记录。
  @@index([usedByMemberId])
  @@map("activation_codes")
}

/// 藏品内容版本。
/// 同一藏品可以拥有多个编辑版本，公开页始终指向当前生效版本。
model CollectionContentVersion {
  /// 内容版本主键。
  id                String                          @id @default(cuid())
  /// 所属藏品外键。
  collectionId      String                          @map("collection_id")
  /// 单藏品内递增版本号。
  versionNo         Int                             @map("version_no")
  /// 展示标题。
  title             String                          @default("")
  /// 展示摘要。
  summary           String                          @default("")
  /// 封面图地址。
  coverImageUrl     String?                         @map("cover_image_url")
  /// 结构化内容载荷，一期使用 JSON 承载。
  contentPayload    Json                            @default("{}") @map("content_payload")
  /// 当前编辑状态。
  editStatus        CollectionContentEditStatus     @default(DRAFT) @map("edit_status")
  /// 当前公开发布状态。
  publishStatus     CollectionContentPublishStatus  @default(UNPUBLISHED) @map("publish_status")
  /// 提交审核时间。
  submittedAt       DateTime?                       @map("submitted_at")
  /// 实际发布时间。
  publishedAt       DateTime?                       @map("published_at")
  /// 创建该内容版本的会员外键。
  createdByMemberId String?                         @map("created_by_member_id")
  /// 创建时间。
  createdAt         DateTime                        @default(now()) @map("created_at")
  /// 更新时间。
  updatedAt         DateTime                        @updatedAt @map("updated_at")
  /// 所属藏品实体。
  collection        Collection                      @relation(fields: [collectionId], references: [id])
  /// 创建该版本的会员实体。
  createdByMember   Member?                         @relation(fields: [createdByMemberId], references: [id])
  /// 该版本关联的审核记录。
  reviewRecords     CollectionContentReviewRecord[]
  /// 该版本关联的评论快照。
  comments          CollectionComment[]

  /// 保证同一藏品下的版本号唯一且单调递增。
  @@unique([collectionId, versionNo])
  /// 支撑按藏品读取内容版本列表与最新版本。
  @@index([collectionId])
  /// 支撑按编辑状态筛选待处理内容。
  @@index([editStatus])
  /// 支撑按公开状态筛选内容展示结果。
  @@index([publishStatus])
  @@map("collection_content_versions")
}

/// 藏品内容审核记录。
/// 记录机审和人工复核过程，不直接等同于公开状态。
model CollectionContentReviewRecord {
  /// 审核记录主键。
  id                    String                        @id @default(cuid())
  /// 所属藏品外键。
  collectionId          String                        @map("collection_id")
  /// 对应内容版本外键。
  contentVersionId      String                        @map("content_version_id")
  /// 审核阶段，机审或人工。
  reviewStage           CollectionContentReviewStage  @map("review_stage")
  /// 审核结果状态。
  reviewStatus          CollectionContentReviewStatus @map("review_status")
  /// 审核来源，系统或管理员。
  reviewSource          CollectionContentReviewSource @map("review_source")
  /// 审核原因或备注。
  reviewReason          String?                       @map("review_reason")
  /// 执行人工审核的后台用户外键。
  reviewedByAdminUserId String?                       @map("reviewed_by_admin_user_id")
  /// 审核完成时间。
  reviewedAt            DateTime?                     @map("reviewed_at")
  /// 审核记录创建时间。
  createdAt             DateTime                      @default(now()) @map("created_at")
  /// 所属藏品实体。
  collection            Collection                    @relation(fields: [collectionId], references: [id])
  /// 对应内容版本实体。
  contentVersion        CollectionContentVersion      @relation(fields: [contentVersionId], references: [id])
  /// 执行人工审核的后台用户实体。
  reviewedByAdminUser   AdminUser?                    @relation(fields: [reviewedByAdminUserId], references: [id])

  /// 支撑按藏品追溯全部审核历史。
  @@index([collectionId])
  /// 支撑按内容版本查询对应审核记录。
  @@index([contentVersionId])
  /// 支撑后台按审核状态查询审核队列。
  @@index([reviewStatus])
  /// 支撑区分机审与人工审核阶段的处理队列。
  @@index([reviewStage])
  @@map("collection_content_review_records")
}

/// 公开评论实体。
/// 一期支持一级评论和二级回复，评论绑定到公开内容版本快照。
model CollectionComment {
  /// 评论主键。
  id               String                          @id @default(cuid())
  /// 所属藏品外键。
  collectionId     String                          @map("collection_id")
  /// 关联的内容版本外键。
  contentVersionId String                          @map("content_version_id")
  /// 评论会员外键。
  memberId         String                          @map("member_id")
  /// 父评论外键；一级评论为空。
  parentCommentId  String?                         @map("parent_comment_id")
  /// 根评论外键；一级评论为空。
  rootCommentId    String?                         @map("root_comment_id")
  /// 评论正文。
  content          String
  /// 当前评论审核/展示状态。
  status           CollectionCommentStatus         @map("status")
  /// 实际公开发布时间。
  publishedAt      DateTime?                       @map("published_at")
  /// 创建时间。
  createdAt        DateTime                        @default(now()) @map("created_at")
  /// 更新时间。
  updatedAt        DateTime                        @updatedAt @map("updated_at")
  /// 所属藏品实体。
  collection       Collection                      @relation(fields: [collectionId], references: [id])
  /// 对应内容版本实体。
  contentVersion   CollectionContentVersion        @relation(fields: [contentVersionId], references: [id])
  /// 发布该评论的会员实体。
  member           Member                          @relation(fields: [memberId], references: [id])
  /// 父评论实体。
  parentComment    CollectionComment?              @relation("CollectionCommentReplies", fields: [parentCommentId], references: [id])
  /// 当前评论的回复列表。
  replies          CollectionComment[]             @relation("CollectionCommentReplies")
  /// 根评论实体。
  rootComment      CollectionComment?              @relation("CollectionCommentRoot", fields: [rootCommentId], references: [id])
  /// 作为根评论时的全部后代回复。
  threadedReplies  CollectionComment[]             @relation("CollectionCommentRoot")
  /// 该评论关联的审核记录。
  reviewRecords    CollectionCommentReviewRecord[]

  /// 支撑按藏品查询评论列表。
  @@index([collectionId])
  /// 支撑按内容版本查询评论快照。
  @@index([contentVersionId])
  /// 支撑按会员查询评论行为。
  @@index([memberId])
  /// 支撑公开列表按状态筛选。
  @@index([status])
  /// 支撑回复树读取。
  @@index([parentCommentId])
  /// 支撑根评论聚合读取。
  @@index([rootCommentId])
  @@map("collection_comments")
}

/// 评论审核记录。
/// 记录评论从机审到人工审核的过程，供后台治理与会员反馈使用。
model CollectionCommentReviewRecord {
  /// 审核记录主键。
  id                    String                        @id @default(cuid())
  /// 对应评论外键。
  commentId             String                        @map("comment_id")
  /// 审核结果状态。
  reviewStatus          CollectionCommentStatus       @map("review_status")
  /// 审核来源。
  reviewSource          CollectionCommentReviewSource @map("review_source")
  /// 审核原因或备注。
  reviewReason          String?                       @map("review_reason")
  /// 执行人工审核的后台用户外键。
  reviewedByAdminUserId String?                       @map("reviewed_by_admin_user_id")
  /// 审核完成时间。
  reviewedAt            DateTime?                     @map("reviewed_at")
  /// 审核记录创建时间。
  createdAt             DateTime                      @default(now()) @map("created_at")
  /// 对应评论实体。
  comment               CollectionComment             @relation(fields: [commentId], references: [id])
  /// 执行人工审核的后台用户实体。
  reviewedByAdminUser   AdminUser?                    @relation(fields: [reviewedByAdminUserId], references: [id])

  /// 支撑按评论追溯审核轨迹。
  @@index([commentId])
  /// 支撑按审核状态筛选队列。
  @@index([reviewStatus])
  @@map("collection_comment_review_records")
}

/// 藏品转让单。
/// 记录指定会员转让与转让码转让的发起、接收与完成状态。
model CollectionTransferOrder {
  /// 转让单主键。
  id           String                   @id @default(cuid())
  /// 对外展示的转让单号。
  transferNo   String                   @unique @map("transfer_no")
  /// 所属藏品外键。
  collectionId String                   @map("collection_id")
  /// 转出会员外键。
  fromMemberId String                   @map("from_member_id")
  /// 转入会员外键；转让码待接收时允许为空。
  toMemberId   String?                  @map("to_member_id")
  /// 转让方式。
  transferMode CollectionTransferMode   @map("transfer_mode")
  /// 转让码；指定会员转让时为空。
  transferCode String?                  @map("transfer_code")
  /// 当前转让状态。
  status       CollectionTransferStatus @map("status")
  /// 失效时间。
  expiredAt    DateTime?                @map("expired_at")
  /// 完成时间。
  completedAt  DateTime?                @map("completed_at")
  /// 创建时间。
  createdAt    DateTime                 @default(now()) @map("created_at")
  /// 更新时间。
  updatedAt    DateTime                 @updatedAt @map("updated_at")
  /// 所属藏品实体。
  collection   Collection               @relation(fields: [collectionId], references: [id])
  /// 转出会员实体。
  fromMember   Member                   @relation("CollectionTransferFromMember", fields: [fromMemberId], references: [id])
  /// 转入会员实体。
  toMember     Member?                  @relation("CollectionTransferToMember", fields: [toMemberId], references: [id])
  /// 该转让单对应的后台运营处置记录。
  operationRecords CollectionTransferOperationRecord[]

  /// 支撑按藏品追溯流转历史。
  @@index([collectionId])
  /// 支撑按转出会员查询其发起记录。
  @@index([fromMemberId])
  /// 支撑按转入会员查询待接收/已接收记录。
  @@index([toMemberId])
  /// 支撑按状态筛选后台转让列表。
  @@index([status])
  /// 支撑按转让方式筛选后台转让列表。
  @@index([transferMode])
  @@map("collection_transfer_orders")
}

/// 转让运营处置记录。
/// 记录后台对异常转让的人工修复动作与前后快照，供追溯和对账使用。
model CollectionTransferOperationRecord {
  /// 处置记录主键。
  id                 String                          @id @default(cuid())
  /// 对应转让单外键。
  transferId         String                          @map("transfer_id")
  /// 处置动作类型。
  actionType         CollectionTransferOperationType @map("action_type")
  /// 运营处置原因。
  reason             String
  /// 操作前快照；当前记录转让状态与藏品归属等关键信息。
  beforeSnapshot     Json                            @map("before_snapshot")
  /// 操作后快照；用于对账和复盘。
  afterSnapshot      Json                            @map("after_snapshot")
  /// 执行处置的后台用户外键；系统补偿或匿名场景允许为空。
  operatorAdminUserId String?                        @map("operator_admin_user_id")
  /// 记录创建时间。
  createdAt          DateTime                        @default(now()) @map("created_at")
  /// 对应转让单实体。
  transfer           CollectionTransferOrder         @relation(fields: [transferId], references: [id])
  /// 执行处置的后台用户实体。
  operatorAdminUser  AdminUser?                      @relation(fields: [operatorAdminUserId], references: [id])

  /// 支撑按转让单读取运营处置时间线。
  @@index([transferId, createdAt])
  /// 支撑按动作类型汇总运营处置分布。
  @@index([actionType])
  /// 支撑按管理员追溯其处置记录。
  @@index([operatorAdminUserId])
  @@map("collection_transfer_operation_records")
}

/// 会员通知消息。
/// 一期默认承载站内信主记录，并挂接站外发送明细。
model NotificationMessage {
  /// 通知消息主键。
  id              String                  @id @default(cuid())
  /// 目标会员外键。
  memberId        String                  @map("member_id")
  /// 消息类型。
  messageType     NotificationMessageType @map("message_type")
  /// 消息标题。
  title           String
  /// 消息正文。
  content         String
  /// 已读时间；未读时为空。
  readAt          DateTime?               @map("read_at")
  /// 创建时间。
  createdAt       DateTime                @default(now()) @map("created_at")
  /// 目标会员实体。
  member          Member                  @relation(fields: [memberId], references: [id])
  /// 该消息的发送记录。
  dispatchRecords NotificationDispatchRecord[]

  /// 支撑按会员读取消息中心。
  @@index([memberId])
  /// 支撑按消息类型汇总后台通知中心。
  @@index([messageType])
  /// 支撑按未读态统计。
  @@index([readAt])
  @@map("notification_messages")
}

/// 通知模板主表。
/// 每种消息类型一条模板定义，当前版本指向最新生效文案。
model NotificationTemplate {
  /// 模板主键。
  id               String                     @id @default(cuid())
  /// 绑定的消息类型；当前约定一类消息对应一个模板。
  templateKey      NotificationMessageType   @unique @map("template_key")
  /// 后台展示名。
  displayName      String                     @map("display_name")
  /// 运营说明。
  description      String?                    @map("description")
  /// 模板状态。
  status           NotificationTemplateStatus @default(ACTIVE)
  /// 当前生效版本外键。
  currentVersionId String?                    @unique @map("current_version_id")
  /// 创建时间。
  createdAt        DateTime                   @default(now()) @map("created_at")
  /// 更新时间。
  updatedAt        DateTime                   @updatedAt @map("updated_at")
  /// 当前生效版本。
  currentVersion   NotificationTemplateVersion? @relation("NotificationTemplateCurrentVersion", fields: [currentVersionId], references: [id])
  /// 历史版本。
  versions         NotificationTemplateVersion[] @relation("NotificationTemplateVersions")

  /// 支撑按状态筛选模板。
  @@index([status])
  @@map("notification_templates")
}

/// 通知模板版本。
/// 每次编辑都会生成新版本，保留历史留痕。
model NotificationTemplateVersion {
  /// 版本主键。
  id         String                      @id @default(cuid())
  /// 所属模板外键。
  templateId String                      @map("template_id")
  /// 版本号；同模板内递增。
  version    Int
  /// 本次变更说明。
  changeNote String?                     @map("change_note")
  /// 创建时间。
  createdAt  DateTime                    @default(now()) @map("created_at")
  /// 所属模板实体。
  template   NotificationTemplate        @relation("NotificationTemplateVersions", fields: [templateId], references: [id])
  /// 多渠道文案明细。
  channels   NotificationTemplateChannel[]
  /// 反向关联：如果当前模板正指向本版本，可从此字段回查。
  currentFor NotificationTemplate?       @relation("NotificationTemplateCurrentVersion")

  /// 支撑模板详情按版本倒序展示。
  @@index([templateId, version])
  /// 保证单个模板内版本号唯一。
  @@unique([templateId, version])
  @@map("notification_template_versions")
}

/// 通知模板版本下的渠道文案。
/// 一条记录对应一个渠道的标题与正文模板。
model NotificationTemplateChannel {
  /// 渠道文案主键。
  id        String                      @id @default(cuid())
  /// 所属版本外键。
  versionId String                      @map("version_id")
  /// 触达渠道。
  channel   NotificationChannel
  /// 渠道标题模板。
  title     String
  /// 渠道正文模板。
  content   String
  /// 创建时间。
  createdAt DateTime                    @default(now()) @map("created_at")
  /// 所属版本实体。
  version   NotificationTemplateVersion @relation(fields: [versionId], references: [id])

  /// 保证同一版本内同渠道只有一份文案。
  @@unique([versionId, channel])
  /// 支撑按渠道聚合模板覆盖范围。
  @@index([channel])
  @@map("notification_template_channels")
}

/// 通知发送记录。
/// 记录站内外各渠道的派发结果与失败原因。
model NotificationDispatchRecord {
  /// 发送记录主键。
  id               String                   @id @default(cuid())
  /// 对应消息外键。
  messageId        String                   @map("message_id")
  /// 发送渠道。
  channel          NotificationChannel
  /// 发送状态。
  status           NotificationDispatchStatus
  /// 渠道侧返回或失败原因。
  providerResponse String?                  @map("provider_response")
  /// 实际发送时间；未发送成功时可为空。
  sentAt           DateTime?                @map("sent_at")
  /// 创建时间。
  createdAt        DateTime                 @default(now()) @map("created_at")
  /// 对应通知消息实体。
  message          NotificationMessage      @relation(fields: [messageId], references: [id])

  /// 支撑按消息追溯全部派发记录。
  @@index([messageId])
  /// 支撑按渠道汇总发送情况。
  @@index([channel])
  /// 支撑按发送状态筛选失败/待发送。
  @@index([status])
  @@map("notification_dispatch_records")
}
