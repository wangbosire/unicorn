PORT=3000
# 与仓库根目录 `docker-compose.yml` 中的 MySQL 一致：用户 root，密码 root123..
# 宿主机连库用 127.0.0.1；若 API 进程跑在 compose 网络内，应使用主机名 mysql（见 compose 中的 service 名）。
DATABASE_URL="mysql://root:root123..@127.0.0.1:3306/unicorn"
# Redis 连接串；通知派发队列与异步副作用使用。
# 宿主机直连用 127.0.0.1；compose 网络内用主机名 redis。
REDIS_URL="redis://127.0.0.1:6379"
# 后台 JWT 密钥，至少 16 字符；生产环境务必覆盖默认值。
ADMIN_JWT_SECRET="dev-admin-jwt-secret-change-me"
# 为 1 / true / yes 时，5xx 错误响应可附带 debug.stack，仅用于本地排障；勿在生产开启。
API_DEBUG_ERRORS="1"
# 为 1 / true / yes 时，同步机审占位通过后不立即公开，进入后台「待人工复核」队列；默认关闭以保持 M2 机审即发布。
CONTENT_MANUAL_GATE_AFTER_MACHINE="0"
